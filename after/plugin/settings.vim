" Basics
set autoindent
set encoding=utf-8
set mouse=a
set nobackup
set noswapfile
set nowrap
set nowritebackup
set number
set relativenumber
set scrolloff=0 " Maintain cursor in the middle
set shiftwidth=0
set smarttab
set tabstop=2 " Tabs appear as 2 spaces width
set updatetime=300
set background=dark

filetype plugin indent on
